{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentskills:schema:skill-manifest:v1",
  "title": "Cumasach Skill Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageType",
    "name",
    "version",
    "skill"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "packageType": {
      "const": "skill"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entrypoint"
      ],
      "properties": {
        "entrypoint": {
          "const": "SKILL.md"
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "relationship"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "type": "string",
            "enum": [
              "required",
              "recommended",
              "extends"
            ]
          }
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "binaries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "os": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "darwin",
              "linux",
              "windows"
            ]
          }
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agentSkills": {
          "type": "string",
          "minLength": 1
        },
        "runtimes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "version"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "repository": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "publisher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
