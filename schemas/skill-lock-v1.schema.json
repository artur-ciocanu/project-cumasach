{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cumasach.dev/schemas/skill-lock-v1.schema.json",
  "title": "Cumasach Skill Lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "root",
    "packages"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "reference"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "reference": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "digest",
          "reference",
          "relationship"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "reference": {
            "type": "string",
            "minLength": 1
          },
          "relationship": {
            "type": "string",
            "enum": [
              "root",
              "required",
              "recommended",
              "extends"
            ]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
            }
          }
        }
      }
    }
  }
}
