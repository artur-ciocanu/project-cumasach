{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agentskills:schema:skill-lock:v1",
  "title": "Cumasach Skill Lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "root",
    "packages",
    "edges"
  ],
  "properties": {
    "schemaVersion": {
      "const": "v1"
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "reference"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
        },
        "reference": {
          "type": "string",
          "pattern": "^oci://[^@]+@sha256:[a-f0-9]{64}$",
          "description": "Digest-pinned OCI artifact reference using the OCI manifest digest."
        }
      }
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "version",
          "digest",
          "reference"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
          },
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "reference": {
            "type": "string",
            "pattern": "^oci://[^@]+@sha256:[a-f0-9]{64}$",
            "description": "Digest-pinned OCI artifact reference using the OCI manifest digest."
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from",
          "to",
          "relationship"
        ],
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
          },
          "to": {
            "type": "string",
            "pattern": "^[a-z0-9]([a-z0-9._-]*[a-z0-9])?$"
          },
          "relationship": {
            "type": "string",
            "enum": [
              "required",
              "recommended",
              "extends"
            ]
          }
        }
      }
    }
  }
}
